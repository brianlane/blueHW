# === NemoClaw Trading Bot — Cron Schedule ===

# BTC 15M Fast Scanner: every 1 minute, 24/7 (no Telegram — writes to events file)
* * * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/btc15m_scanner.py >> /tmp/btc15m_scanner.log 2>&1"

# Crypto Scanner: every 5 min, 24/7 (no Telegram — writes to events file)
*/5 * * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/crypto_scanner.py >> /tmp/crypto_scanner.log 2>&1"

# Main Kalshi Scanner: every 5 min, 24/7 (no Telegram — writes to events file)
*/5 * * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/auto_scan.py >> /tmp/scan.log 2>&1"

# 6-HOUR DIGEST: comprehensive AI brief at 00:00, 06:00, 12:00, 18:00 UTC
0 0,6,12,18 * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/digest.py >> /tmp/digest.log 2>&1"

# Research Agent: 8 AM and 8 PM UTC (learns from losses, updates strategy)
0 8,20 * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/research_agent.py >> /tmp/research.log 2>&1"

# Evolutionary Tuning: Sunday 3 AM UTC
0 3 * * 0 /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && cd /home/ubuntu/.openclaw/workspace && python3 scripts/evolutionary.py >> /tmp/evolution.log 2>&1"

# Guardian health check: every minute
* * * * * /bin/bash -c "source /home/ubuntu/.openclaw/.env.tradingbot && python3 /home/ubuntu/.openclaw/workspace/scripts/guardian.py >> /tmp/guardian.log 2>&1"

# Daily position reconciliation (6AM UTC)
0 6 * * * cd /home/ubuntu/.openclaw/workspace && python3 scripts/reconcile.py >> /tmp/reconcile.log 2>&1

# Keep Ollama warm
*/4 * * * * curl -s --max-time 15 -X POST http://localhost:11434/api/chat -H "Content-Type: application/json" -d '{"model":"qwen3.5:2b","messages":[{"role":"user","content":"ok"}],"stream":false,"keep_alive":"10m","options":{"num_predict":1}}' > /dev/null 2>&1

# Session compression (weekly/monthly/yearly)
0 4 * * 0 cd /home/ubuntu/.openclaw/workspace && python3 scripts/compress_sessions.py weekly >> /tmp/compress.log 2>&1
30 4 1 * * cd /home/ubuntu/.openclaw/workspace && python3 scripts/compress_sessions.py monthly >> /tmp/compress.log 2>&1
0 5 1 1 * cd /home/ubuntu/.openclaw/workspace && python3 scripts/compress_sessions.py yearly >> /tmp/compress.log 2>&1
0 4 * * 0 /home/ubuntu/.openclaw/workspace/scripts/compress_logs.sh >> /tmp/compress.log 2>&1
